# Admin Dashboard - Cloudflare Access Authentication
# Configure these for production email OTP auth:
CF_ACCESS_TEAM_DOMAIN=your-team-name          # "myteam" from myteam.cloudflareaccess.com
CF_ACCESS_AUD=your-application-audience-tag    # AUD tag from CF Access app settings
CF_ACCESS_ALLOWED_EMAILS=admin@example.com     # Comma-separated list of allowed admin emails

# Dev fallback (only used when CF Access vars are not set)
ADMIN_PASSWORD=admin
