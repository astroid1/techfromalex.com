---
import Base from "@/layouts/Base.astro";
import Container from "@/components/layout/Container.astro";
import PostCard from "@/components/blog/PostCard.astro";
import { getDB } from "@/lib/db";
import { listPublished } from "@/lib/content";
import { CATEGORY_NAMES } from "@/lib/types";

export const prerender = false;
const db = getDB(Astro.locals);
const posts = await listPublished(db, { limit: 10 });
const featured = posts[0] ?? null;
const rest = posts.slice(1, 7);
const cats = Object.entries(CATEGORY_NAMES);
---

<Base>
  <section class="border-b border-line bg-surface">
    <Container width="wide" class="py-12 sm:py-16">
      <div class="grid items-center gap-10 lg:grid-cols-[1fr_1.05fr]">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest text-accent-strong">Tech, tested honestly</p>
          <h1 class="mt-3 font-display text-4xl font-bold leading-[1.04] tracking-tight text-ink sm:text-5xl lg:text-6xl">
            Reviews you can <span class="text-accent-strong">actually trust</span>.
          </h1>
          <p class="mt-4 max-w-md text-lg leading-relaxed text-ink-soft">
            Hands-on reviews, no-nonsense buying guides, and the deals worth your money — from
            someone who buys the gear himself.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a
              href="/blog"
              class="rounded-xl bg-accent px-5 py-3 font-semibold text-accent-contrast shadow-[var(--shadow-md)] transition hover:brightness-105"
            >
              Browse all reviews
            </a>
            <a
              href="/deals"
              class="rounded-xl border border-line-strong px-5 py-3 font-semibold text-ink transition hover:bg-surface-2"
            >
              Today's deals
            </a>
          </div>
        </div>
        {featured && (
          <div class="rise">
            <PostCard item={featured} featured />
          </div>
        )}
      </div>
    </Container>
  </section>

  <Container width="wide" class="py-14">
    <div class="flex items-end justify-between">
      <h2 class="font-display text-2xl font-bold text-ink">Latest</h2>
      <a href="/blog" class="text-sm font-medium text-accent-strong hover:underline">View all →</a>
    </div>
    {
      rest.length > 0 ? (
        <div class="mt-7 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {rest.map((p) => (
            <PostCard item={p} />
          ))}
        </div>
      ) : (
        <p class="mt-7 rounded-2xl border border-line bg-surface p-8 text-muted">More reviews coming soon.</p>
      )
    }
  </Container>

  <Container width="wide" class="pb-16">
    <div class="rounded-2xl border border-line bg-surface p-8 text-center">
      <h2 class="font-display text-2xl font-bold text-ink">Find what you need</h2>
      <p class="mx-auto mt-2 max-w-md text-ink-soft">Jump straight to the gear you're shopping for.</p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        {
          cats.map(([slug, name]) => (
            <a
              href={slug === "deals" ? "/deals" : `/category/${slug}`}
              class="rounded-full border border-line-strong px-4 py-2 text-sm font-medium text-ink-soft transition hover:border-accent hover:text-accent-strong"
            >
              {name}
            </a>
          ))
        }
      </div>
    </div>
  </Container>
</Base>
