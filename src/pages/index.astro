---
import Base from "../layouts/Base.astro";

export const prerender = false;

const { env } = Astro.locals.runtime;

let categories: { slug: string; name: string }[] = [];
let dbError: string | null = null;
try {
  const res = await env.DB.prepare(
    "SELECT slug, name FROM categories ORDER BY position",
  ).all<{ slug: string; name: string }>();
  categories = res.results ?? [];
} catch (e) {
  dbError = (e as Error).message;
}
---

<Base title="Tech From Alex — rebuilding on Cloudflare">
  <main class="mx-auto max-w-2xl px-4 py-16">
    <p class="text-sm font-medium uppercase tracking-widest" style="color:var(--accent)">
      Phase 0 · Foundation
    </p>
    <h1 class="mt-2 text-4xl font-extrabold tracking-tight">Tech From Alex</h1>
    <p class="mt-3 text-lg">
      Astro&nbsp;5 + Cloudflare SSR foundation is live. The page below was
      server-rendered and read live from D1.
    </p>

    <section class="mt-8 rounded-xl border border-black/10 bg-white/60 p-5">
      <h2 class="text-sm font-semibold uppercase tracking-wide opacity-70">
        Categories (from D1)
      </h2>
      {
        dbError ? (
          <pre class="mt-2 overflow-auto text-sm text-red-700">{dbError}</pre>
        ) : (
          <ul class="mt-3 space-y-1">
            {categories.map((c) => (
              <li>
                <span class="font-semibold">{c.name}</span>
                <code class="ml-2 text-sm opacity-60">/{c.slug}</code>
              </li>
            ))}
          </ul>
        )
      }
    </section>
  </main>
</Base>
