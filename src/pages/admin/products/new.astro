---
import AdminLayout from "@/layouts/AdminLayout.astro";
import ProductForm from "@/components/admin/ProductForm.astro";
import { getDB } from "@/lib/db";
import { nowIso, ulid } from "@/lib/ids";
import { slugify } from "@/lib/format";
import { parseProductForm } from "@/lib/admin";

export const prerender = false;
const db = getDB(Astro.locals);
let error: string | null = null;
let values: Record<string, any> = {};

if (Astro.request.method === "POST") {
  const f = await Astro.request.formData();
  const p = parseProductForm(f);
  values = {
    name: p.name, brand: p.brand, category: p.category, image_url: p.image_url,
    price: f.get("price"), rating: f.get("rating"), description: p.description,
    prosText: p.pros.join("\n"), consText: p.cons.join("\n"),
    specsText: Object.entries(p.specs).map(([k, v]) => `${k}: ${v}`).join("\n"),
  };
  if (!p.name) error = "Name is required.";
  if (!error) {
    let id = slugify(p.name);
    const exists = await db.prepare("SELECT 1 FROM products WHERE id = ?").bind(id).first();
    if (exists) id = `${id}-${ulid().slice(-4).toLowerCase()}`;
    const now = nowIso();
    try {
      await db
        .prepare(
          `INSERT INTO products (id,name,brand,category,image_url,price_cents,currency,price_source,rating,description,pros_json,cons_json,specs_json,created_at,updated_at)
           VALUES (?,?,?,?,?,?, 'USD','manual', ?,?,?,?,?,?,?)`,
        )
        .bind(
          id, p.name, p.brand, p.category, p.image_url, p.price_cents, p.rating, p.description,
          JSON.stringify(p.pros), JSON.stringify(p.cons), JSON.stringify(p.specs), now, now,
        )
        .run();
      return Astro.redirect(`/admin/products/${id}`);
    } catch (e) {
      error = (e as Error).message;
    }
  }
}
---

<AdminLayout title="New product">
  <ProductForm values={values} error={error} submitLabel="Create product" />
  <p class="mt-4 max-w-2xl text-sm text-muted">After creating, you'll add affiliate buy links (per network) on the product's edit page.</p>
</AdminLayout>
