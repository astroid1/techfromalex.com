---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getDB } from "@/lib/db";
import { formatPrice } from "@/lib/format";

export const prerender = false;
const db = getDB(Astro.locals);
const imported = Astro.url.searchParams.get("imported");
const rows =
  (await db
    .prepare(
      `SELECT p.id, p.name, p.brand, p.category, p.price_cents, p.currency,
              (SELECT COUNT(*) FROM product_links pl WHERE pl.product_id = p.id) AS links
       FROM products p ORDER BY p.name`,
    )
    .all<any>()).results ?? [];
---

<AdminLayout title="Products">
  {
    imported && (
      <p class="mb-4 rounded-lg px-4 py-2 text-sm" style="color:var(--success);background:color-mix(in srgb,var(--success) 12%,transparent)">
        Imported {imported} product{imported === "1" ? "" : "s"} from Amazon.
      </p>
    )
  }
  <div class="flex items-center justify-between gap-4">
    <p class="max-w-xl text-sm text-muted">Products power affiliate cards and comparisons. Add buy links per product on its edit page.</p>
    <div class="flex shrink-0 gap-2">
      <a href="/admin/products/import" class="rounded-xl border border-line-strong px-4 py-2.5 font-semibold transition hover:bg-surface-2">Import from Amazon</a>
      <a href="/admin/products/new" class="rounded-xl bg-accent px-4 py-2.5 font-semibold text-accent-contrast transition hover:brightness-105">+ New product</a>
    </div>
  </div>

  <div class="mt-6 overflow-hidden rounded-xl border border-line bg-surface">
    <table class="w-full text-sm">
      <thead class="bg-surface-2 text-left text-xs uppercase tracking-wide text-muted">
        <tr><th class="p-3 font-semibold">Name</th><th class="p-3 font-semibold">Brand</th><th class="p-3 font-semibold">Category</th><th class="p-3 font-semibold">Price</th><th class="p-3 font-semibold">Links</th></tr>
      </thead>
      <tbody>
        {
          rows.length ? (
            rows.map((p: any) => (
              <tr class="border-t border-line">
                <td class="p-3"><a href={`/admin/products/${p.id}`} class="font-medium hover:text-accent-strong">{p.name}</a></td>
                <td class="p-3 text-muted">{p.brand ?? "—"}</td>
                <td class="p-3 text-muted">{p.category ?? "—"}</td>
                <td class="p-3">{formatPrice(p.price_cents, p.currency) ?? "—"}</td>
                <td class="p-3 text-muted">{p.links}</td>
              </tr>
            ))
          ) : (
            <tr><td colspan="5" class="p-6 text-center text-muted">No products yet. <a href="/admin/products/new" class="text-accent-strong">Add one →</a></td></tr>
          )
        }
      </tbody>
    </table>
  </div>
</AdminLayout>
