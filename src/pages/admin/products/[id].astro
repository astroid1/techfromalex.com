---
import AdminLayout from "@/layouts/AdminLayout.astro";
import ProductForm from "@/components/admin/ProductForm.astro";
import { getDB, getEnv } from "@/lib/db";
import { nowIso, ulid } from "@/lib/ids";
import { parseProductForm } from "@/lib/admin";
import { runAmazonScrape, mapApifyItem } from "@/lib/apify";

export const prerender = false;
const { id } = Astro.params;
const db = getDB(Astro.locals);
const env = getEnv(Astro.locals);
let error: string | null = null;
let notice: string | null = null;

let p = await db.prepare("SELECT * FROM products WHERE id = ?").bind(id).first<any>();
if (!p) return Astro.redirect("/admin/products");
if (Astro.url.searchParams.get("imported")) notice = "Imported from Amazon — review the details below, then Save.";

if (Astro.request.method === "POST") {
  const f = await Astro.request.formData();
  const action = String(f.get("__action") ?? "save");

  if (action === "delete") {
    try {
      await db.prepare("DELETE FROM products WHERE id = ?").bind(id).run();
      return Astro.redirect("/admin/products");
    } catch {
      error = "Can't delete — this product is referenced by an article. Remove it from that content first.";
    }
  } else if (action === "addLink") {
    const profile = String(f.get("affiliate_profile_id") ?? "");
    const baseUrl = String(f.get("base_url") ?? "").trim();
    const isPrimary = f.get("is_primary") ? 1 : 0;
    if (!profile || !baseUrl) error = "Pick a profile and enter a URL.";
    else {
      try {
        await db
          .prepare(
            `INSERT INTO product_links (id,product_id,affiliate_profile_id,base_url,is_primary,created_at,updated_at) VALUES (?,?,?,?,?,?,?)`,
          )
          .bind(ulid(), id, profile, baseUrl, isPrimary, nowIso(), nowIso())
          .run();
        notice = "Link added.";
      } catch (e) {
        error = String((e as Error).message).includes("UNIQUE")
          ? "A link for that profile already exists on this product."
          : (e as Error).message;
      }
    }
  } else if (action === "removeLink") {
    await db
      .prepare("DELETE FROM product_links WHERE id = ? AND product_id = ?")
      .bind(String(f.get("linkId") ?? ""), id)
      .run();
    notice = "Link removed.";
  } else if (action === "refetch") {
    const link = await db
      .prepare(
        `SELECT pl.base_url FROM product_links pl JOIN affiliate_profiles ap ON ap.id = pl.affiliate_profile_id
         WHERE pl.product_id = ? AND ap.network = 'amazon' ORDER BY pl.is_primary DESC LIMIT 1`,
      )
      .bind(id)
      .first<{ base_url: string }>();
    if (!link?.base_url) error = "No Amazon link to refresh from — add an Amazon buy link first.";
    else {
      try {
        const raw = await runAmazonScrape(env, { urls: [link.base_url], maxResults: 1 });
        const item = raw.map(mapApifyItem).filter((x) => x.name)[0];
        if (!item) error = "Couldn't fetch fresh data from Amazon.";
        else {
          const now = nowIso();
          await db
            .prepare(
              `UPDATE products SET price_cents=COALESCE(?,price_cents), currency=?, price_source='apify',
                 price_observed_at=?, rating=COALESCE(?,rating), category=COALESCE(NULLIF(category,''), ?), updated_at=? WHERE id=?`,
            )
            .bind(item.priceCents, item.currency, now, item.rating, item.category, now, id)
            .run();
          notice = "Refreshed price, rating & category from Amazon.";
        }
      } catch (e) {
        error = (e as Error).message;
      }
    }
  } else {
    const pf = parseProductForm(f);
    if (!pf.name) error = "Name is required.";
    if (!error) {
      try {
        await db
          .prepare(
            `UPDATE products SET name=?,brand=?,category=?,image_url=?,price_cents=?,rating=?,description=?,pros_json=?,cons_json=?,specs_json=?,updated_at=? WHERE id=?`,
          )
          .bind(
            pf.name, pf.brand, pf.category, pf.image_url, pf.price_cents, pf.rating, pf.description,
            JSON.stringify(pf.pros), JSON.stringify(pf.cons), JSON.stringify(pf.specs), nowIso(), id,
          )
          .run();
        notice = "Saved.";
      } catch (e) {
        error = (e as Error).message;
      }
    }
  }
  p = await db.prepare("SELECT * FROM products WHERE id = ?").bind(id).first<any>();
}

const pros = JSON.parse(p.pros_json || "[]");
const cons = JSON.parse(p.cons_json || "[]");
const specs = JSON.parse(p.specs_json || "{}");
const values = {
  name: p.name, brand: p.brand, category: p.category, image_url: p.image_url,
  price: p.price_cents != null ? p.price_cents / 100 : "", rating: p.rating ?? "",
  description: p.description, prosText: pros.join("\n"), consText: cons.join("\n"),
  specsText: Object.entries(specs).map(([k, v]) => `${k}: ${v}`).join("\n"),
};
const links =
  (await db
    .prepare(
      `SELECT pl.id, pl.base_url, pl.is_primary, ap.name AS profile_name, ap.network
       FROM product_links pl JOIN affiliate_profiles ap ON ap.id = pl.affiliate_profile_id
       WHERE pl.product_id = ? ORDER BY pl.is_primary DESC`,
    )
    .bind(id)
    .all<any>()).results ?? [];
const profiles =
  (await db.prepare("SELECT id,name FROM affiliate_profiles WHERE is_active=1 ORDER BY name").all<any>())
    .results ?? [];
const input =
  "mt-1 w-full rounded-lg border border-line-strong bg-paper px-3 py-2 text-ink outline-none transition focus-visible:border-accent";
---

<AdminLayout title="Edit product">
  {notice && <p class="mb-4 rounded-lg px-4 py-2 text-sm" style="color:var(--success);background:color-mix(in srgb,var(--success) 12%,transparent)">{notice}</p>}
  {error && <p class="mb-4 rounded-lg px-4 py-2 text-sm" style="color:var(--danger);background:color-mix(in srgb,var(--danger) 12%,transparent)">{error}</p>}

  <ProductForm values={values} submitLabel="Save product" />

  <section class="mt-8 max-w-2xl rounded-xl border border-line bg-surface p-5">
    <div class="flex items-start justify-between gap-3">
      <div>
        <h2 class="font-display text-lg font-bold">Affiliate buy links</h2>
        <p class="mt-1 text-sm text-muted">Each link maps a retailer URL to an affiliate profile. The primary link powers the Buy button.</p>
      </div>
      {
        links.some((l: any) => l.network === "amazon") && (
          <form method="POST" data-refetch class="shrink-0">
            <input type="hidden" name="__action" value="refetch" />
            <button class="rounded-lg border border-line-strong px-3 py-2 text-sm font-semibold text-accent-strong transition hover:bg-surface-2">↻ Refresh from Amazon</button>
          </form>
        )
      }
    </div>

    {
      links.length > 0 && (
        <ul class="mt-4 divide-y divide-line">
          {links.map((l: any) => (
            <li class="flex items-center gap-3 py-2 text-sm">
              <span class="font-medium">{l.profile_name}</span>
              {l.is_primary ? <span class="rounded bg-accent px-1.5 py-0.5 text-xs text-accent-contrast">primary</span> : null}
              <code class="min-w-0 flex-1 truncate text-xs text-muted" title={l.base_url}>{l.base_url}</code>
              <form method="POST">
                <input type="hidden" name="__action" value="removeLink" />
                <input type="hidden" name="linkId" value={l.id} />
                <button class="text-xs font-semibold" style="color:var(--danger)">Remove</button>
              </form>
            </li>
          ))}
        </ul>
      )
    }

    <form method="POST" class="mt-4 flex flex-wrap items-end gap-3">
      <input type="hidden" name="__action" value="addLink" />
      <label class="block">
        <span class="text-sm font-medium">Profile</span>
        <select name="affiliate_profile_id" class={input}>
          {profiles.map((pr: any) => <option value={pr.id}>{pr.name}</option>)}
        </select>
      </label>
      <label class="block flex-1 min-w-[16rem]">
        <span class="text-sm font-medium">Retailer URL</span>
        <input name="base_url" class={input} placeholder="https://www.amazon.com/dp/…" />
      </label>
      <label class="flex items-center gap-2 pb-2"><input type="checkbox" name="is_primary" value="1" /><span class="text-sm">Primary</span></label>
      <button class="rounded-xl border border-line-strong px-4 py-2.5 font-semibold transition hover:bg-surface-2">Add link</button>
    </form>
  </section>

  <form method="POST" class="mt-6 max-w-2xl">
    <input type="hidden" name="__action" value="delete" />
    <button class="text-sm font-semibold" style="color:var(--danger)" onclick="return confirm('Delete this product permanently?')">Delete product</button>
  </form>

  <div data-rf-overlay hidden class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm">
    <div class="rounded-2xl border border-line bg-surface px-6 py-5 text-center">
      <p class="font-display text-lg font-bold text-ink">↻ Refreshing from Amazon…</p>
      <p class="mt-1 text-sm text-muted">Fetching the latest price &amp; rating. ~10–30s.</p>
    </div>
  </div>
  <script is:inline>
    (function () {
      var form = document.querySelector("form[data-refetch]");
      var ov = document.querySelector("[data-rf-overlay]");
      if (form && ov) form.addEventListener("submit", function () { ov.hidden = false; ov.style.display = "flex"; });
    })();
  </script>
</AdminLayout>
