---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getDB } from "@/lib/db";

export const prerender = false;
const db = getDB(Astro.locals);
const rows = await db
  .prepare("SELECT id, name, network, tracking_tag, is_active FROM affiliate_profiles ORDER BY name")
  .all<{ id: string; name: string; network: string; tracking_tag: string; is_active: number }>();
const profiles = rows.results ?? [];
---

<AdminLayout title="Affiliate profiles">
  <div class="flex items-center justify-between gap-4">
    <p class="max-w-xl text-sm text-muted">
      Reusable affiliate accounts. Create one per network/account, then select it on products and
      articles — links are built with its tag automatically.
    </p>
    <a href="/admin/affiliates/new" class="shrink-0 rounded-xl bg-accent px-4 py-2.5 font-semibold text-accent-contrast transition hover:brightness-105">
      + New profile
    </a>
  </div>

  <div class="mt-6 overflow-hidden rounded-xl border border-line bg-surface">
    <table class="w-full text-sm">
      <thead class="bg-surface-2 text-left text-xs uppercase tracking-wide text-muted">
        <tr>
          <th class="p-3 font-semibold">Name</th>
          <th class="p-3 font-semibold">Network</th>
          <th class="p-3 font-semibold">Tag</th>
          <th class="p-3 font-semibold">Active</th>
        </tr>
      </thead>
      <tbody>
        {
          profiles.length ? (
            profiles.map((p) => (
              <tr class="border-t border-line">
                <td class="p-3">
                  <a href={`/admin/affiliates/${p.id}`} class="font-medium hover:text-accent-strong">{p.name}</a>
                </td>
                <td class="p-3 text-muted">{p.network}</td>
                <td class="p-3"><code class="text-xs">{p.tracking_tag}</code></td>
                <td class="p-3">{p.is_active ? "Yes" : "No"}</td>
              </tr>
            ))
          ) : (
            <tr>
              <td colspan="4" class="p-6 text-center text-muted">
                No profiles yet. <a href="/admin/affiliates/new" class="text-accent-strong">Add one →</a>
              </td>
            </tr>
          )
        }
      </tbody>
    </table>
  </div>
</AdminLayout>
