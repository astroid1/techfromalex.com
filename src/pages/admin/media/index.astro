---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getDB } from "@/lib/db";
import { formatDate } from "@/lib/format";

export const prerender = false;
const db = getDB(Astro.locals);
const error = Astro.url.searchParams.get("error");
const rows =
  (await db
    .prepare("SELECT id, url_path, alt, mime, bytes, created_at FROM media ORDER BY created_at DESC LIMIT 200")
    .all<{ id: string; url_path: string; alt: string; mime: string; bytes: number; created_at: string }>())
    .results ?? [];

// "Where used" — built from a few bulk queries (not one per media row): an /img/
// path is referenced by a content hero, inline in an article body, a product
// image, or a program logo. Map url_path -> list of usages.
type Use = { label: string; href: string; kind: string };
const usage = new Map<string, Use[]>();
const add = (path: string | null | undefined, u: Use) => {
  if (!path) return;
  const arr = usage.get(path) ?? [];
  arr.push(u);
  usage.set(path, arr);
};

const contentRows =
  (await db
    .prepare("SELECT id, title, status, hero_image_url, body_md FROM content")
    .all<{ id: string; title: string; status: string; hero_image_url: string | null; body_md: string | null }>())
    .results ?? [];
for (const c of contentRows) {
  if (c.hero_image_url) add(c.hero_image_url, { label: c.title, href: `/admin/content/${c.id}`, kind: `hero · ${c.status}` });
  const inBody = new Set([...String(c.body_md ?? "").matchAll(/\/img\/[\w./-]+/g)].map((m) => m[0]));
  for (const p of inBody) {
    if (p !== c.hero_image_url) add(p, { label: c.title, href: `/admin/content/${c.id}`, kind: `in article · ${c.status}` });
  }
}
const productRows =
  (await db.prepare("SELECT id, name, image_url FROM products").all<{ id: string; name: string; image_url: string | null }>())
    .results ?? [];
for (const p of productRows) add(p.image_url, { label: p.name, href: `/admin/products/${p.id}`, kind: "product image" });

const programRows =
  (await db.prepare("SELECT id, name, logo_url FROM programs").all<{ id: string; name: string; logo_url: string | null }>())
    .results ?? [];
for (const pg of programRows) add(pg.logo_url, { label: pg.name, href: `/admin/programs/${pg.id}`, kind: "program logo" });

const input =
  "mt-1 w-full rounded-lg border border-line-strong bg-paper px-3 py-2 text-ink outline-none transition focus-visible:border-accent";
const kb = (n: number) => `${Math.round(n / 1024)} KB`;
---

<AdminLayout title="Media">
  {error && <p class="mb-4 rounded-lg px-4 py-2 text-sm" style="color:var(--danger);background:color-mix(in srgb,var(--danger) 12%,transparent)">{error}</p>}

  <div class="rounded-xl border border-line bg-surface p-5">
    <h2 class="font-display text-lg font-bold">Upload an image</h2>
    <p class="mt-1 text-sm text-muted">Uploads go to R2 and are served from <code>/img/…</code>. Copy a path onto a product or article.</p>
    <form method="POST" action="/api/admin/media/upload" enctype="multipart/form-data" class="mt-4 flex flex-wrap items-end gap-4">
      <label class="block">
        <span class="text-sm font-medium">File</span>
        <input type="file" name="file" accept="image/*" required class="mt-1 block text-sm" />
      </label>
      <label class="block flex-1 min-w-[16rem]">
        <span class="text-sm font-medium">Alt text (required)</span>
        <input name="alt" required class={input} placeholder="Describe the image for accessibility & SEO" />
      </label>
      <button class="rounded-xl bg-accent px-5 py-2.5 font-semibold text-accent-contrast transition hover:brightness-105">Upload</button>
    </form>
  </div>

  <h2 class="mt-8 font-display text-lg font-bold">Library</h2>
  {
    rows.length ? (
      <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {rows.map((m) => {
          const used = usage.get(m.url_path) ?? [];
          return (
            <div class="flex flex-col overflow-hidden rounded-xl border border-line bg-surface">
              <a href={m.url_path} target="_blank" rel="noopener" class="block aspect-video bg-surface-2" title="Open image in a new tab">
                <img src={m.url_path} alt={m.alt} loading="lazy" class="h-full w-full object-contain" />
              </a>
              <div class="flex min-w-0 flex-1 flex-col p-3">
                <p class="truncate text-sm font-medium" title={m.alt}>{m.alt}</p>
                <p class="mt-0.5 text-xs text-muted">{kb(m.bytes)} · {formatDate(m.created_at)}</p>
                <a
                  href={m.url_path}
                  target="_blank"
                  rel="noopener"
                  class="mt-1 block truncate text-xs text-accent-strong hover:underline"
                  title={`Open ${m.url_path}`}
                >
                  {m.url_path} ↗
                </a>
                <div class="mt-2 border-t border-line pt-2">
                  {used.length ? (
                    <>
                      <p class="text-[11px] font-semibold uppercase tracking-wide text-muted">
                        Used in ({used.length})
                      </p>
                      <ul class="mt-1 space-y-0.5">
                        {used.map((u) => (
                          <li class="truncate text-xs" title={`${u.label} — ${u.kind}`}>
                            <a href={u.href} class="text-ink-soft hover:text-accent-strong">{u.label}</a>
                            <span class="text-muted"> · {u.kind}</span>
                          </li>
                        ))}
                      </ul>
                    </>
                  ) : (
                    <p class="text-[11px] text-muted">Not used yet</p>
                  )}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <p class="mt-4 rounded-xl border border-line bg-surface p-6 text-muted">No images yet. Upload one above.</p>
    )
  }
</AdminLayout>
