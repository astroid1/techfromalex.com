---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getDB } from "@/lib/db";
import { formatDate } from "@/lib/format";

export const prerender = false;
const db = getDB(Astro.locals);
const status = Astro.url.searchParams.get("status") ?? "";
const valid = ["draft", "in_review", "scheduled", "published", "unpublished"];
const filter = valid.includes(status) ? status : "";

const rows = filter
  ? await db
      .prepare("SELECT id,title,type,status,category,updated_at, json_extract(structured_json,'$.aiStatus') AS ai_status FROM content WHERE status=? ORDER BY updated_at DESC LIMIT 200")
      .bind(filter)
      .all<any>()
  : await db
      .prepare("SELECT id,title,type,status,category,updated_at, json_extract(structured_json,'$.aiStatus') AS ai_status FROM content ORDER BY updated_at DESC LIMIT 200")
      .all<any>();
const items = rows.results ?? [];
const anyGenerating = items.some((i: any) => i.ai_status === "generating");

const tabs = [
  { label: "All", value: "" },
  { label: "Published", value: "published" },
  { label: "Draft", value: "draft" },
  { label: "In review", value: "in_review" },
  { label: "Scheduled", value: "scheduled" },
];
const statusColor: Record<string, string> = {
  published: "var(--success)",
  draft: "var(--muted)",
  in_review: "var(--accent)",
  scheduled: "var(--cat-news)",
  unpublished: "var(--danger)",
};
---

<AdminLayout title="Content">
  <div class="flex items-center justify-between gap-4">
    <div class="flex flex-wrap gap-1">
      {
        tabs.map((t) => (
          <a
            href={t.value ? `/admin/content?status=${t.value}` : "/admin/content"}
            class={`rounded-lg px-3 py-1.5 text-sm font-medium transition ${filter === t.value ? "bg-accent text-accent-contrast" : "text-ink-soft hover:bg-surface-2"}`}
          >
            {t.label}
          </a>
        ))
      }
    </div>
    <div class="flex shrink-0 gap-2">
      <a href="/admin/content/youtube" class="rounded-xl border border-line-strong px-4 py-2.5 font-semibold transition hover:bg-surface-2">
        ▶ From YouTube
      </a>
      <a href="/admin/content/new" class="rounded-xl bg-accent px-4 py-2.5 font-semibold text-accent-contrast transition hover:brightness-105">
        + New content
      </a>
    </div>
  </div>

  <div class="mt-6 overflow-hidden rounded-xl border border-line bg-surface">
    <table class="w-full text-sm">
      <thead class="bg-surface-2 text-left text-xs uppercase tracking-wide text-muted">
        <tr>
          <th class="p-3 font-semibold">Title</th>
          <th class="p-3 font-semibold">Type</th>
          <th class="p-3 font-semibold">Category</th>
          <th class="p-3 font-semibold">Status</th>
          <th class="p-3 font-semibold">Updated</th>
        </tr>
      </thead>
      <tbody>
        {
          items.length ? (
            items.map((r: any) => (
              <tr class="border-t border-line">
                <td class="p-3">
                  <a href={`/admin/content/${r.id}`} class="font-medium hover:text-accent-strong">{r.title}</a>
                  {r.ai_status === "generating" && (
                    <span class="ml-2 inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[11px] font-semibold" style="color:var(--accent-strong);background:color-mix(in srgb,var(--accent) 14%,transparent)">🪄 drafting…</span>
                  )}
                </td>
                <td class="p-3 text-muted">{r.type}</td>
                <td class="p-3 text-muted">{r.category ?? "—"}</td>
                <td class="p-3">
                  <span class="inline-flex items-center gap-1.5 text-xs font-semibold" style={`color:${statusColor[r.status] ?? "var(--muted)"}`}>
                    <span class="h-1.5 w-1.5 rounded-full" style={`background:${statusColor[r.status] ?? "var(--muted)"}`} />
                    {r.status}
                  </span>
                </td>
                <td class="p-3 text-muted">{formatDate(r.updated_at)}</td>
              </tr>
            ))
          ) : (
            <tr>
              <td colspan="5" class="p-6 text-center text-muted">
                Nothing here. <a href="/admin/content/new" class="text-accent-strong">Create content →</a>
              </td>
            </tr>
          )
        }
      </tbody>
    </table>
  </div>
  {anyGenerating && <script is:inline>setTimeout(function () { location.reload(); }, 10000);</script>}
</AdminLayout>
