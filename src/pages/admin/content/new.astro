---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getDB, getEnv } from "@/lib/db";
import { ulid, nowIso } from "@/lib/ids";
import { slugify } from "@/lib/format";
import { uniqueSlug, attachProductsToContent } from "@/lib/admin";
import { runGenerationJob } from "@/lib/ai/generate";
import { CONTENT_TYPES, TYPE_CATEGORY } from "@/lib/content-meta";
import { listActivePrograms } from "@/lib/programs";

export const prerender = false;
const db = getDB(Astro.locals);

// Products with their primary active affiliate profile (so the form can derive + show it).
const products =
  (
    await db
      .prepare(
        `SELECT p.id, p.name, p.brand,
                (SELECT ap.name FROM product_links pl JOIN affiliate_profiles ap ON ap.id = pl.affiliate_profile_id
                 WHERE pl.product_id = p.id AND ap.is_active = 1 ORDER BY pl.is_primary DESC LIMIT 1) AS profile_name
         FROM products p ORDER BY p.name`,
      )
      .all<{ id: string; name: string; brand: string | null; profile_name: string | null }>()
  ).results ?? [];
const cats = (await db.prepare("SELECT slug,name FROM categories ORDER BY position").all<any>()).results ?? [];
const programOpts = await listActivePrograms(db);

const types = CONTENT_TYPES;
const typeCategory = TYPE_CATEGORY;

let error: string | null = null;
if (Astro.request.method === "POST") {
  const f = await Astro.request.formData();
  const isGenerate = String(f.get("__action") ?? "create") === "generate";
  const type = String(f.get("type") ?? "review");
  const title = String(f.get("title") ?? "").trim();
  const category = String(f.get("category") ?? "") || null;
  const keyword = String(f.get("primaryKeyword") ?? "").trim();
  const brief = String(f.get("brief") ?? "").trim();
  const instructions = String(f.get("instructions") ?? "").trim();
  const productIds = f.getAll("productIds").map(String).filter(Boolean);
  const programIds = f.getAll("programIds").map(String).filter(Boolean);

  if (!title) error = "A title or topic is required.";
  else {
    const id = ulid();
    const slug = await uniqueSlug(db, slugify(title));
    const now = nowIso();
    const structured = JSON.stringify({
      primaryKeyword: keyword,
      brief,
      instructions,
      ...(programIds.length ? { programIds } : {}),
      ...(isGenerate ? { aiStatus: "generating" } : {}),
    });
    try {
      await db
        .prepare(
          `INSERT INTO content (id,type,status,slug,title,dek,category,author_id,body_md,structured_json,seo_title,seo_description,created_at,updated_at)
           VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?)`,
        )
        .bind(id, type, "draft", slug, title, null, category, "alex", "", structured, null, null, now, now)
        .run();
      await attachProductsToContent(db, id, productIds);
      // Generate in the background so the page returns immediately. The draft is
      // already persisted (status 'draft'); generation fills it in and marks aiStatus done.
      if (isGenerate) {
        Astro.locals.runtime.ctx.waitUntil(runGenerationJob(getEnv(Astro.locals), db, id));
      }
      return Astro.redirect(`/admin/content/${id}`);
    } catch (e) {
      error = (e as Error).message;
    }
  }
}

const input =
  "mt-1 w-full rounded-lg border border-line-strong bg-paper px-3 py-2 text-ink outline-none transition focus-visible:border-accent";
---

<AdminLayout title="New content">
  <form method="POST" id="content-form" class="max-w-2xl space-y-5">
    {
      error && (
        <p class="rounded-lg px-4 py-2 text-sm" style="color:var(--danger); background:color-mix(in srgb,var(--danger) 12%,transparent)">
          {error}
        </p>
      )
    }
    <div class="grid gap-5 sm:grid-cols-2">
      <label class="block">
        <span class="text-sm font-medium">Content type</span>
        <select name="type" data-type class={input}>
          {types.map((t) => <option value={t.value} data-cat={typeCategory[t.value] ?? ""}>{t.label}</option>)}
        </select>
      </label>
      <label class="block">
        <span class="text-sm font-medium">Category <span class="font-normal text-muted">(auto from type)</span></span>
        <select name="category" data-category class={input}>
          <option value="">— none —</option>
          {cats.map((c: any) => <option value={c.slug}>{c.name}</option>)}
        </select>
      </label>
    </div>

    <label class="block">
      <span class="text-sm font-medium">Title / topic</span>
      <input name="title" required class={input} placeholder="e.g. Sony WH-1000XM6 Review" />
    </label>
    <label class="block">
      <span class="text-sm font-medium">Primary keyword <span class="font-normal text-muted">(optional — guides SEO)</span></span>
      <input name="primaryKeyword" class={input} placeholder="sony wh-1000xm6 review" />
    </label>
    <label class="block">
      <span class="text-sm font-medium">Brief / angle <span class="font-normal text-muted">(for AI generation)</span></span>
      <textarea name="brief" rows="3" class={input} placeholder="What should this piece argue or cover? Who is it for?"></textarea>
    </label>
    <label class="block">
      <span class="text-sm font-medium">Additional AI instructions <span class="font-normal text-muted">(optional)</span></span>
      <textarea name="instructions" rows="3" class={input} placeholder="Extra directives — tone, must-mention points, length, comparisons to make, things to avoid…"></textarea>
    </label>
    <p class="rounded-lg border border-line bg-surface-2 px-3 py-2 text-xs text-muted">
      SEO title &amp; meta description are generated automatically from the content (editable later in the editor).
    </p>

    <fieldset class="rounded-xl border border-line p-4">
      <legend class="px-1 text-sm font-medium">Featured products</legend>
      {
        products.length ? (
          <div class="mt-1">
            <input type="search" data-prod-search placeholder="Search products by name or brand…" autocomplete="off" class={input} />
            <div class="mt-3 max-h-64 overflow-y-auto rounded-lg border border-line">
              {products.map((p) => (
                <label
                  class="flex items-center gap-2 border-b border-line px-3 py-2 text-sm last:border-0"
                  data-prod
                  data-search={`${p.name} ${p.brand ?? ""}`.toLowerCase()}
                >
                  <input type="checkbox" name="productIds" value={p.id} data-profile={p.profile_name ?? ""} class="shrink-0" />
                  <span class="min-w-0 flex-1 truncate">
                    {p.name}
                    {p.brand ? <span class="text-muted"> · {p.brand}</span> : null}
                  </span>
                  {p.profile_name ? (
                    <span class="shrink-0 text-xs text-muted">{p.profile_name}</span>
                  ) : (
                    <span class="shrink-0 text-xs" style="color:var(--danger)">no link</span>
                  )}
                </label>
              ))}
            </div>
            <p class="mt-2 text-xs text-muted">
              <span data-prod-count>0</span> selected · Affiliate: <span data-prod-profiles class="text-ink-soft">—</span>
            </p>
          </div>
        ) : (
          <p class="mt-2 text-sm text-muted">
            No products yet — <a href="/admin/products/import" class="text-accent-strong">import from Amazon</a> or add under Products.
          </p>
        )
      }
    </fieldset>

    <fieldset class="rounded-xl border border-line p-4">
      <legend class="px-1 text-sm font-medium">Promote a service / program (optional)</legend>
      {
        programOpts.length ? (
          <div class="mt-1 space-y-1.5">
            {programOpts.map((pg: any) => (
              <label class="flex items-center gap-2 text-sm">
                <input type="checkbox" name="programIds" value={pg.id} class="shrink-0" />
                <span>{pg.name}</span>
              </label>
            ))}
            <p class="mt-1 text-xs text-muted">The AI writes a short section about each selected service and adds a tagged ::promo CTA.</p>
          </div>
        ) : (
          <p class="mt-2 text-sm text-muted">
            No programs yet — <a href="/admin/programs/new" class="text-accent-strong">add one</a> (e.g. make.com).
          </p>
        )
      }
    </fieldset>

    <div class="flex items-center gap-3 pt-2">
      <button name="__action" value="generate" class="rounded-xl bg-accent px-5 py-2.5 font-semibold text-accent-contrast transition hover:brightness-105">
        ✨ Create &amp; draft with AI
      </button>
      <button name="__action" value="create" class="rounded-xl border border-line-strong px-5 py-2.5 font-semibold transition hover:bg-surface-2">
        Create empty draft
      </button>
    </div>
    <p class="text-xs text-muted">Affiliate profiles are taken from the selected products' links. AI drafting runs in the background — you'll land in the editor and can keep working while it writes.</p>
  </form>

  <div data-create-overlay hidden class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm">
    <div class="rounded-2xl border border-line bg-surface px-6 py-5 text-center">
      <p class="font-display text-lg font-bold text-ink" data-create-title>Creating draft…</p>
      <p class="mt-1 text-sm text-muted">Taking you to the editor…</p>
    </div>
  </div>

  <script is:inline>
    (function () {
      var typeSel = document.querySelector("[data-type]");
      var catSel = document.querySelector("[data-category]");
      function syncCat() {
        if (!typeSel || !catSel) return;
        var opt = typeSel.options[typeSel.selectedIndex];
        var want = opt && opt.getAttribute("data-cat");
        if (want) {
          for (var i = 0; i < catSel.options.length; i++) {
            if (catSel.options[i].value === want) { catSel.selectedIndex = i; break; }
          }
        }
      }
      if (typeSel) typeSel.addEventListener("change", syncCat);
      syncCat();

      var search = document.querySelector("[data-prod-search]");
      if (search)
        search.addEventListener("input", function () {
          var q = search.value.toLowerCase().trim();
          document.querySelectorAll("[data-prod]").forEach(function (row) {
            row.style.display = !q || row.getAttribute("data-search").indexOf(q) !== -1 ? "" : "none";
          });
        });

      var count = document.querySelector("[data-prod-count]");
      var profEl = document.querySelector("[data-prod-profiles]");
      function syncSel() {
        var checked = document.querySelectorAll('input[name="productIds"]:checked');
        if (count) count.textContent = String(checked.length);
        var profs = {};
        checked.forEach(function (c) {
          var p = c.getAttribute("data-profile");
          if (p) profs[p] = 1;
        });
        var names = Object.keys(profs);
        if (profEl) profEl.textContent = names.length ? names.join(", ") : "—";
      }
      document.querySelectorAll('input[name="productIds"]').forEach(function (c) {
        c.addEventListener("change", syncSel);
      });
      syncSel();

      // Prevent double-submit (which would create duplicate drafts) + show progress.
      var form = document.getElementById("content-form");
      var overlay = document.querySelector("[data-create-overlay]");
      var submitting = false;
      if (form)
        form.addEventListener("submit", function (e) {
          if (submitting) { e.preventDefault(); return; }
          submitting = true;
          var isGen = e.submitter && e.submitter.value === "generate";
          var t = overlay && overlay.querySelector("[data-create-title]");
          if (t) t.textContent = isGen ? "✨ Creating draft & starting the AI…" : "Creating draft…";
          if (overlay) { overlay.hidden = false; overlay.style.display = "flex"; }
        });
    })();
  </script>
</AdminLayout>
