---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getDB, getEnv } from "@/lib/db";
import { ulid, nowIso } from "@/lib/ids";
import { slugify } from "@/lib/format";
import { uniqueSlug } from "@/lib/admin";
import { generateDraft } from "@/lib/ai/generate";

export const prerender = false;
const db = getDB(Astro.locals);
const products = (await db.prepare("SELECT id,name,brand FROM products ORDER BY name").all<any>()).results ?? [];
const profiles =
  (await db.prepare("SELECT id,name FROM affiliate_profiles WHERE is_active=1 ORDER BY name").all<any>()).results ?? [];
const cats = (await db.prepare("SELECT slug,name FROM categories ORDER BY position").all<any>()).results ?? [];

const types = [
  { value: "review", label: "Single-product Review" },
  { value: "comparison", label: "Head-to-head Comparison" },
  { value: "roundup", label: "'Best X' Roundup / Guide" },
  { value: "news_deal", label: "News & Deal post" },
];

let error: string | null = null;
if (Astro.request.method === "POST") {
  const f = await Astro.request.formData();
  const type = String(f.get("type") ?? "review");
  const title = String(f.get("title") ?? "").trim();
  const category = String(f.get("category") ?? "") || null;
  const keyword = String(f.get("primaryKeyword") ?? "").trim();
  const brief = String(f.get("brief") ?? "").trim();
  const dek = String(f.get("dek") ?? "").trim() || null;
  const productIds = f.getAll("productIds").map(String);
  const profileId = String(f.get("affiliate_profile_id") ?? "") || null;

  if (!title) error = "A title or topic is required.";
  else {
    const id = ulid();
    const slug = await uniqueSlug(db, slugify(title));
    const now = nowIso();
    const structured = JSON.stringify({ primaryKeyword: keyword, brief });
    try {
      await db
        .prepare(
          `INSERT INTO content (id,type,status,slug,title,dek,category,author_id,body_md,structured_json,seo_title,seo_description,created_at,updated_at)
           VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?)`,
        )
        .bind(id, type, "draft", slug, title, dek, category, "alex", "", structured, title, dek, now, now)
        .run();
      for (let i = 0; i < productIds.length; i++) {
        await db
          .prepare(
            `INSERT OR IGNORE INTO content_products (content_id,product_id,role,position,affiliate_profile_id) VALUES (?,?,?,?,?)`,
          )
          .bind(id, productIds[i], i === 0 ? "primary" : "featured", i, profileId)
          .run();
      }
      if (profileId) {
        await db
          .prepare(`INSERT OR IGNORE INTO content_affiliate_profiles (content_id,affiliate_profile_id) VALUES (?,?)`)
          .bind(id, profileId)
          .run();
      }
      if (String(f.get("__action") ?? "create") === "generate") {
        try {
          await generateDraft(getEnv(Astro.locals), db, id);
        } catch (e) {
          return Astro.redirect(
            `/admin/content/${id}?gen_error=${encodeURIComponent((e as Error).message)}`,
          );
        }
      }
      return Astro.redirect(`/admin/content/${id}`);
    } catch (e) {
      error = (e as Error).message;
    }
  }
}

const input =
  "mt-1 w-full rounded-lg border border-line-strong bg-paper px-3 py-2 text-ink outline-none transition focus-visible:border-accent";
---

<AdminLayout title="New content">
  <form method="POST" class="max-w-2xl space-y-5">
    {
      error && (
        <p class="rounded-lg px-4 py-2 text-sm" style="color:var(--danger); background:color-mix(in srgb,var(--danger) 12%,transparent)">
          {error}
        </p>
      )
    }
    <div class="grid gap-5 sm:grid-cols-2">
      <label class="block">
        <span class="text-sm font-medium">Content type</span>
        <select name="type" class={input}>
          {types.map((t) => <option value={t.value}>{t.label}</option>)}
        </select>
      </label>
      <label class="block">
        <span class="text-sm font-medium">Category</span>
        <select name="category" class={input}>
          <option value="">— none —</option>
          {cats.map((c: any) => <option value={c.slug}>{c.name}</option>)}
        </select>
      </label>
    </div>
    <label class="block">
      <span class="text-sm font-medium">Title / topic</span>
      <input name="title" required class={input} placeholder="e.g. Sony WH-1000XM6 Review" />
    </label>
    <label class="block">
      <span class="text-sm font-medium">Primary keyword (SEO)</span>
      <input name="primaryKeyword" class={input} placeholder="sony wh-1000xm6 review" />
    </label>
    <label class="block">
      <span class="text-sm font-medium">Brief / angle (for AI generation)</span>
      <textarea name="brief" rows="3" class={input} placeholder="What should this piece argue or cover? Who is it for?"></textarea>
    </label>
    <label class="block">
      <span class="text-sm font-medium">Meta description</span>
      <input name="dek" class={input} placeholder="One-sentence summary for search & social." />
    </label>

    <fieldset class="rounded-xl border border-line p-4">
      <legend class="px-1 text-sm font-medium">Featured products</legend>
      {
        products.length ? (
          <div class="mt-2 grid gap-2 sm:grid-cols-2">
            {products.map((p: any) => (
              <label class="flex items-center gap-2 text-sm">
                <input type="checkbox" name="productIds" value={p.id} />
                <span>{p.name}</span>
              </label>
            ))}
          </div>
        ) : (
          <p class="mt-2 text-sm text-muted">No products yet — add some under Products.</p>
        )
      }
    </fieldset>

    <label class="block">
      <span class="text-sm font-medium">Affiliate profile for these links</span>
      <select name="affiliate_profile_id" class={input}>
        <option value="">— product default —</option>
        {profiles.map((p: any) => <option value={p.id}>{p.name}</option>)}
      </select>
    </label>

    <div class="flex items-center gap-3 pt-2">
      <button name="__action" value="generate" class="rounded-xl bg-accent px-5 py-2.5 font-semibold text-accent-contrast transition hover:brightness-105">
        ✨ Create &amp; draft with AI
      </button>
      <button name="__action" value="create" class="rounded-xl border border-line-strong px-5 py-2.5 font-semibold transition hover:bg-surface-2">
        Create empty draft
      </button>
    </div>
    <p class="text-xs text-muted">AI generation runs in the editor after the draft is created.</p>
  </form>
</AdminLayout>
