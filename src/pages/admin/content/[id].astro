---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getDB, getEnv } from "@/lib/db";
import { nowIso } from "@/lib/ids";
import { slugify, formatDate } from "@/lib/format";
import {
  uniqueSlug,
  syncFts,
  removeFts,
  writeRevision,
  purgeContent,
  productIdsInBody,
} from "@/lib/admin";
import { assertReferences, ReferentialError } from "@/lib/validate";
import { generateDraft } from "@/lib/ai/generate";

export const prerender = false;
const { id } = Astro.params;
const db = getDB(Astro.locals);
const env = getEnv(Astro.locals);
const user = Astro.locals.user;
let notice: string | null = null;
let error: string | null = Astro.url.searchParams.get("gen_error");

let c = await db.prepare("SELECT * FROM content WHERE id = ?").bind(id).first<any>();
if (!c) return Astro.redirect("/admin/content");

if (Astro.request.method === "POST") {
  const f = await Astro.request.formData();
  const action = String(f.get("__action") ?? "save");

  if (action === "delete") {
    await removeFts(db, id!);
    await db.prepare("DELETE FROM content WHERE id = ?").bind(id).run();
    return Astro.redirect("/admin/content");
  } else if (action === "ai_generate") {
    try {
      await generateDraft(env, db, id!);
      c = await db.prepare("SELECT * FROM content WHERE id = ?").bind(id).first<any>();
      notice = "AI draft generated — review and edit below.";
    } catch (e) {
      error = (e as Error).message;
    }
  } else {
    const title = String(f.get("title") ?? "").trim();
  const slugInput = slugify(String(f.get("slug") ?? "")) || slugify(title);
  const dek = String(f.get("dek") ?? "").trim() || null;
  const category = String(f.get("category") ?? "") || null;
  const verdict = f.get("verdict_score") ? Number(f.get("verdict_score")) : null;
  const bodyMd = String(f.get("body_md") ?? "");
  const structuredRaw = String(f.get("structured_json") ?? "{}").trim() || "{}";
  const seoTitle = String(f.get("seo_title") ?? "").trim() || null;
  const seoDescription = String(f.get("seo_description") ?? "").trim() || null;
  const heroUrl = String(f.get("hero_image_url") ?? "").trim() || null;
  const heroAlt = String(f.get("hero_alt") ?? "").trim() || null;

  let structured: any = {};
  if (!title) error = "Title is required.";
  try {
    structured = JSON.parse(structuredRaw);
  } catch {
    error = "Structured JSON is invalid.";
  }

  if (!error) {
    const slug = await uniqueSlug(db, slugInput, id!);
    const now = nowIso();
    let status = c.status as string;
    if (action === "submit_review") status = "in_review";
    else if (action === "unpublish") status = "unpublished";
    else if (action === "back_to_draft") status = "draft";

    if (action === "publish") {
      const pidSet = new Set<string>(productIdsInBody(bodyMd));
      if (structured.productId) pidSet.add(structured.productId);
      if (Array.isArray(structured.picks))
        for (const p of structured.picks) if (p.productId) pidSet.add(p.productId);
      if (Array.isArray(structured.entrants)) for (const e of structured.entrants) pidSet.add(e);
      const rel =
        (await db
          .prepare("SELECT product_id, affiliate_profile_id FROM content_products WHERE content_id=?")
          .bind(id)
          .all<any>()).results ?? [];
      const profSet = new Set<string>();
      for (const r of rel) {
        pidSet.add(r.product_id);
        if (r.affiliate_profile_id) profSet.add(r.affiliate_profile_id);
      }
      const caps =
        (await db
          .prepare("SELECT affiliate_profile_id FROM content_affiliate_profiles WHERE content_id=?")
          .bind(id)
          .all<any>()).results ?? [];
      for (const r of caps) profSet.add(r.affiliate_profile_id);
      try {
        await assertReferences(db, { productIds: [...pidSet], profileIds: [...profSet] });
        status = "published";
      } catch (e) {
        error = e instanceof ReferentialError ? e.message : (e as Error).message;
      }
    }

    if (!error) {
      const publishedAt = status === "published" && !c.published_at ? now : c.published_at;
      await db
        .prepare(
          `UPDATE content SET title=?, slug=?, dek=?, category=?, verdict_score=?, body_md=?,
             structured_json=?, seo_title=?, seo_description=?, hero_image_url=?, hero_alt=?,
             status=?, published_at=?, updated_at=? WHERE id=?`,
        )
        .bind(
          title, slug, dek, category, verdict, bodyMd, structuredRaw, seoTitle, seoDescription,
          heroUrl, heroAlt, status, publishedAt, now, id,
        )
        .run();

      const tagRows =
        (await db.prepare("SELECT tag_slug FROM content_tags WHERE content_id=?").bind(id).all<any>())
          .results ?? [];
      const tags = tagRows.map((r: any) => r.tag_slug);
      if (status === "published") {
        await syncFts(db, { id: id!, title, dek, bodyMd, tags });
        await purgeContent(env, slug, category, tags);
      } else {
        await removeFts(db, id!);
      }
      await writeRevision(
        db, id!,
        {
          title, slug, dek, category, verdict_score: verdict, body_md: bodyMd,
          structured_json: structuredRaw, editedBy: user?.email ?? null,
        },
        status, "human", null,
      );
      c = await db.prepare("SELECT * FROM content WHERE id = ?").bind(id).first<any>();
      notice = action === "publish" ? "Published — live now." : action === "unpublish" ? "Unpublished." : "Saved.";
    }
  }
  }
}

const relProducts =
  (await db
    .prepare("SELECT p.name FROM content_products cp JOIN products p ON p.id=cp.product_id WHERE cp.content_id=? ORDER BY cp.position")
    .bind(id)
    .all<any>()).results ?? [];
const revisions =
  (await db
    .prepare("SELECT created_at, source, status_at_save FROM content_revisions WHERE content_id=? ORDER BY created_at DESC LIMIT 8")
    .bind(id)
    .all<any>()).results ?? [];
const cats = (await db.prepare("SELECT slug,name FROM categories ORDER BY position").all<any>()).results ?? [];

let prettyStructured = c.structured_json;
try {
  prettyStructured = JSON.stringify(JSON.parse(c.structured_json || "{}"), null, 2);
} catch {
  /* keep raw */
}
const input =
  "mt-1 w-full rounded-lg border border-line-strong bg-paper px-3 py-2 text-ink outline-none transition focus-visible:border-accent";
---

<AdminLayout title="Edit content">
  {notice && <p class="mb-4 rounded-lg px-4 py-2 text-sm" style="color:var(--success);background:color-mix(in srgb,var(--success) 12%,transparent)">{notice}</p>}
  {error && <p class="mb-4 rounded-lg px-4 py-2 text-sm" style="color:var(--danger);background:color-mix(in srgb,var(--danger) 12%,transparent)">{error}</p>}

  <form method="POST" class="grid gap-8 lg:grid-cols-[1fr_18rem]">
    <div class="min-w-0 space-y-5">
      <label class="block">
        <span class="text-sm font-medium">Title</span>
        <input name="title" value={c.title} required class={input} />
      </label>
      <div class="grid gap-5 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm font-medium">Slug</span>
          <input name="slug" value={c.slug} class={input} />
        </label>
        <label class="block">
          <span class="text-sm font-medium">Category</span>
          <select name="category" class={input}>
            <option value="">— none —</option>
            {cats.map((cat: any) => <option value={cat.slug} selected={c.category === cat.slug}>{cat.name}</option>)}
          </select>
        </label>
      </div>
      <label class="block">
        <span class="text-sm font-medium">Meta description</span>
        <input name="dek" value={c.dek ?? ""} class={input} />
      </label>
      {c.type === "review" && (
        <label class="block max-w-[12rem]">
          <span class="text-sm font-medium">Verdict score (0–10)</span>
          <input name="verdict_score" type="number" min="0" max="10" step="0.1" value={c.verdict_score ?? ""} class={input} />
        </label>
      )}
      <label class="block">
        <span class="text-sm font-medium">Body (directive-markdown)</span>
        <textarea name="body_md" rows="22" class={`${input} font-mono text-sm leading-relaxed`}>{c.body_md}</textarea>
        <span class="mt-1 block text-xs text-muted">
          Use <code>::product-card&#123;id="..."&#125;</code>, <code>::buy-button&#123;id="..."&#125;</code>,
          <code>:::callout</code>, <code>:::pros-cons</code>, and <code>:product[label]&#123;id="..."&#125;</code>.
        </span>
      </label>
      <label class="block">
        <span class="text-sm font-medium">Template data (JSON)</span>
        <textarea name="structured_json" rows="8" class={`${input} font-mono text-sm`}>{prettyStructured}</textarea>
      </label>
      <div class="grid gap-5 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm font-medium">Hero image URL</span>
          <input name="hero_image_url" value={c.hero_image_url ?? ""} class={input} placeholder="/media/... or https://" />
        </label>
        <label class="block">
          <span class="text-sm font-medium">Hero alt text</span>
          <input name="hero_alt" value={c.hero_alt ?? ""} class={input} />
        </label>
      </div>
      <details class="rounded-lg border border-line">
        <summary class="cursor-pointer px-4 py-2 text-sm font-medium">SEO overrides</summary>
        <div class="space-y-4 p-4 pt-0">
          <label class="block"><span class="text-sm font-medium">SEO title</span><input name="seo_title" value={c.seo_title ?? ""} class={input} /></label>
          <label class="block"><span class="text-sm font-medium">SEO description</span><input name="seo_description" value={c.seo_description ?? ""} class={input} /></label>
        </div>
      </details>
    </div>

    <aside class="space-y-5">
      <div class="rounded-xl border border-line bg-surface p-4">
        <p class="text-xs uppercase tracking-wide text-muted">Status</p>
        <p class="mt-1 font-display text-lg font-bold capitalize">{c.status.replace("_", " ")}</p>
        <p class="mt-1 text-xs text-muted">{c.type} · updated {formatDate(c.updated_at)}</p>
        <div class="mt-4 space-y-2">
          <button name="__action" value="save" class="w-full rounded-lg border border-line-strong px-3 py-2 text-sm font-semibold transition hover:bg-surface-2">Save draft</button>
          {c.status !== "published" && (
            <button name="__action" value="publish" class="w-full rounded-lg bg-accent px-3 py-2 text-sm font-semibold text-accent-contrast transition hover:brightness-105">Publish</button>
          )}
          {c.status === "published" && (
            <>
              <button name="__action" value="save" class="w-full rounded-lg bg-accent px-3 py-2 text-sm font-semibold text-accent-contrast transition hover:brightness-105">Save &amp; republish</button>
              <button name="__action" value="unpublish" class="w-full rounded-lg border border-line-strong px-3 py-2 text-sm font-semibold transition hover:bg-surface-2">Unpublish</button>
            </>
          )}
          {c.status === "draft" && (
            <button name="__action" value="submit_review" class="w-full rounded-lg border border-line-strong px-3 py-2 text-sm font-semibold transition hover:bg-surface-2">Submit for review</button>
          )}
          <button name="__action" value="ai_generate" class="w-full rounded-lg border border-line-strong px-3 py-2 text-sm font-semibold text-accent-strong transition hover:bg-surface-2">✨ Regenerate with AI</button>
        </div>
        <div class="mt-3 flex gap-3 text-sm">
          <a href={`/admin/content/${id}/preview`} class="text-accent-strong hover:underline">Preview</a>
          {c.status === "published" && <a href={`/${c.slug}`} target="_blank" class="text-accent-strong hover:underline">View live ↗</a>}
        </div>
      </div>

      {relProducts.length > 0 && (
        <div class="rounded-xl border border-line bg-surface p-4">
          <p class="text-xs uppercase tracking-wide text-muted">Linked products</p>
          <ul class="mt-2 space-y-1 text-sm">{relProducts.map((p: any) => <li>{p.name}</li>)}</ul>
        </div>
      )}

      {revisions.length > 0 && (
        <div class="rounded-xl border border-line bg-surface p-4">
          <p class="text-xs uppercase tracking-wide text-muted">History</p>
          <ul class="mt-2 space-y-1.5 text-xs text-muted">
            {revisions.map((r: any) => (
              <li>{formatDate(r.created_at)} · {r.source} · {r.status_at_save}</li>
            ))}
          </ul>
        </div>
      )}

      <button name="__action" value="delete" class="w-full rounded-lg px-3 py-2 text-sm font-semibold transition hover:bg-surface-2" style="color:var(--danger)" onclick="return confirm('Delete this content permanently?')">Delete</button>
    </aside>
  </form>
</AdminLayout>
