---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getDB, getEnv } from "@/lib/db";
import { ulid, nowIso } from "@/lib/ids";
import { slugify } from "@/lib/format";
import { uniqueSlug } from "@/lib/admin";
import { runGenerationJob } from "@/lib/ai/generate";
import { runYoutubeTranscript, mapTranscript, normalizeYoutubeUrl } from "@/lib/apify";
import { CONTENT_TYPES, TYPE_CATEGORY } from "@/lib/content-meta";

export const prerender = false;
const db = getDB(Astro.locals);
const wordCount = (s: string) => s.split(/\s+/).filter(Boolean).length;

let step: "url" | "draft" = "url";
let error: string | null = null;
let urlValue = "";
let transcript = "";
let videoTitle: string | null = null;
let vals = {
  title: "",
  type: "howto",
  category: TYPE_CATEGORY.howto,
  primaryKeyword: "",
  brief: "",
  instructions: "",
};

if (Astro.request.method === "POST") {
  const f = await Astro.request.formData();
  const action = String(f.get("__action") ?? "");

  if (action === "fetch") {
    urlValue = String(f.get("video_url") ?? "").trim();
    const norm = normalizeYoutubeUrl(urlValue);
    if (!norm) error = "Enter a valid YouTube video URL (watch, youtu.be, shorts…).";
    else {
      try {
        const items = await runYoutubeTranscript(getEnv(Astro.locals), norm);
        const t = mapTranscript(norm, items);
        if (!t.transcript || t.segments === 0) {
          error = "No transcript found for that video — it may have captions disabled.";
        } else {
          step = "draft";
          urlValue = norm;
          transcript = t.transcript;
          videoTitle = t.title;
          vals.title = t.title ?? "";
        }
      } catch (e) {
        error = (e as Error).message;
      }
    }
  } else if (action === "create") {
    urlValue = String(f.get("video_url") ?? "").trim();
    transcript = String(f.get("transcript") ?? "").trim().slice(0, 80000);
    vals = {
      title: String(f.get("title") ?? "").trim(),
      type: String(f.get("type") ?? "howto"),
      category: String(f.get("category") ?? ""),
      primaryKeyword: String(f.get("primaryKeyword") ?? "").trim(),
      brief: String(f.get("brief") ?? "").trim(),
      instructions: String(f.get("instructions") ?? "").trim(),
    };
    if (!vals.title) error = "A title is required.";
    else if (!transcript) error = "Transcript is empty — fetch the video again.";
    else {
      const id = ulid();
      const slug = await uniqueSlug(db, slugify(vals.title));
      const now = nowIso();
      const structured = JSON.stringify({
        primaryKeyword: vals.primaryKeyword,
        brief: vals.brief,
        instructions: vals.instructions,
        sourceUrl: urlValue,
        sourceTranscript: transcript,
        aiStatus: "generating",
      });
      try {
        await db
          .prepare(
            `INSERT INTO content (id,type,status,slug,title,dek,category,author_id,body_md,structured_json,seo_title,seo_description,created_at,updated_at)
             VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?)`,
          )
          .bind(id, vals.type, "draft", slug, vals.title, null, vals.category || null, "alex", "", structured, null, null, now, now)
          .run();
        Astro.locals.runtime.ctx.waitUntil(runGenerationJob(getEnv(Astro.locals), db, id));
        return Astro.redirect(`/admin/content/${id}`);
      } catch (e) {
        error = (e as Error).message;
      }
    }
    if (error) step = "draft"; // re-render the draft form with the carried values + transcript
  }
}

const cats = (await db.prepare("SELECT slug,name FROM categories ORDER BY position").all<any>()).results ?? [];
const input =
  "mt-1 w-full rounded-lg border border-line-strong bg-paper px-3 py-2 text-ink outline-none transition focus-visible:border-accent";
const words = wordCount(transcript);
---

<AdminLayout title="Write from YouTube">
  {error && <p class="mb-4 rounded-lg px-4 py-2 text-sm" style="color:var(--danger);background:color-mix(in srgb,var(--danger) 12%,transparent)">{error}</p>}

  <p class="max-w-2xl text-sm text-muted">
    Paste a YouTube URL to pull its transcript (via Apify), then draft an article from it with AI. The
    transcript is saved on the draft so you can re-draft or reference it later.
  </p>

  {
    step === "url" ? (
      <form method="POST" id="yt-fetch" class="mt-5 max-w-2xl">
        <input type="hidden" name="__action" value="fetch" />
        <label class="block">
          <span class="text-sm font-medium">YouTube video URL</span>
          <input
            name="video_url"
            required
            value={urlValue}
            class={input}
            placeholder="https://www.youtube.com/watch?v=…  ·  youtu.be/…  ·  /shorts/…"
          />
        </label>
        <button class="mt-4 rounded-xl bg-accent px-5 py-2.5 font-semibold text-accent-contrast transition hover:brightness-105">
          Fetch transcript
        </button>
      </form>
    ) : (
      <div class="mt-5 max-w-2xl">
        <div class="rounded-xl border border-line bg-surface p-4">
          <p class="text-xs font-semibold uppercase tracking-widest text-muted">Transcript fetched</p>
          {videoTitle && <p class="mt-1 font-semibold text-ink">{videoTitle}</p>}
          <p class="mt-1 text-sm text-muted">
            <a href={urlValue} target="_blank" rel="noopener" class="text-accent-strong hover:underline">{urlValue}</a>
            <span> · ~{words} words</span>
          </p>
        </div>

        <form method="POST" id="yt-create" class="mt-5 space-y-5">
          <input type="hidden" name="__action" value="create" />
          <input type="hidden" name="video_url" value={urlValue} />

          <div class="grid gap-5 sm:grid-cols-2">
            <label class="block">
              <span class="text-sm font-medium">Content type</span>
              <select name="type" data-type class={input}>
                {CONTENT_TYPES.map((t) => (
                  <option value={t.value} data-cat={TYPE_CATEGORY[t.value] ?? ""} selected={vals.type === t.value}>
                    {t.label}
                  </option>
                ))}
              </select>
            </label>
            <label class="block">
              <span class="text-sm font-medium">Category <span class="font-normal text-muted">(auto from type)</span></span>
              <select name="category" data-category class={input}>
                <option value="">— none —</option>
                {cats.map((c: any) => (
                  <option value={c.slug} selected={vals.category === c.slug}>{c.name}</option>
                ))}
              </select>
            </label>
          </div>

          <label class="block">
            <span class="text-sm font-medium">Title</span>
            <input name="title" required value={vals.title} class={input} placeholder="Article title" />
          </label>
          <label class="block">
            <span class="text-sm font-medium">Primary keyword <span class="font-normal text-muted">(optional)</span></span>
            <input name="primaryKeyword" value={vals.primaryKeyword} class={input} />
          </label>
          <label class="block">
            <span class="text-sm font-medium">Brief / angle <span class="font-normal text-muted">(optional)</span></span>
            <textarea name="brief" rows="2" class={input} placeholder="How should this be framed? Who is it for?">{vals.brief}</textarea>
          </label>
          <label class="block">
            <span class="text-sm font-medium">Additional AI instructions <span class="font-normal text-muted">(optional)</span></span>
            <textarea name="instructions" rows="2" class={input}>{vals.instructions}</textarea>
          </label>
          <label class="block">
            <span class="text-sm font-medium">Source transcript <span class="font-normal text-muted">(editable — trim intros, sponsor reads, or off-topic parts)</span></span>
            <textarea name="transcript" rows="10" class={`${input} font-mono text-xs leading-relaxed`}>{transcript}</textarea>
          </label>

          <div class="flex items-center gap-3 pt-2">
            <button class="rounded-xl bg-accent px-5 py-2.5 font-semibold text-accent-contrast transition hover:brightness-105">
              ✨ Draft article with AI
            </button>
            <a href="/admin/content/youtube" class="rounded-xl border border-line-strong px-5 py-2.5 font-semibold transition hover:bg-surface-2">
              Start over
            </a>
          </div>
          <p class="text-xs text-muted">AI drafting runs in the background — you'll land in the editor and can keep working while it writes from the transcript.</p>
        </form>
      </div>
    )
  }

  <div data-overlay hidden class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm">
    <div class="rounded-2xl border border-line bg-surface px-6 py-5 text-center">
      <p class="font-display text-lg font-bold text-ink" data-overlay-title>Working…</p>
      <p class="mt-1 text-sm text-muted" data-overlay-sub>This can take a moment.</p>
    </div>
  </div>

  <script is:inline>
    (function () {
      var typeSel = document.querySelector("[data-type]");
      var catSel = document.querySelector("[data-category]");
      if (typeSel && catSel) {
        typeSel.addEventListener("change", function () {
          var opt = typeSel.options[typeSel.selectedIndex];
          var want = opt && opt.getAttribute("data-cat");
          if (want) for (var i = 0; i < catSel.options.length; i++) {
            if (catSel.options[i].value === want) { catSel.selectedIndex = i; break; }
          }
        });
      }

      var overlay = document.querySelector("[data-overlay]");
      function showOverlay(title, sub) {
        if (!overlay) return;
        var t = overlay.querySelector("[data-overlay-title]"); if (t) t.textContent = title;
        var s = overlay.querySelector("[data-overlay-sub]"); if (s) s.textContent = sub;
        overlay.hidden = false; overlay.style.display = "flex";
      }
      var fetchForm = document.getElementById("yt-fetch");
      if (fetchForm) fetchForm.addEventListener("submit", function () {
        showOverlay("Fetching transcript…", "Scraping the video via Apify — this can take up to a minute.");
      });
      var createForm = document.getElementById("yt-create");
      var submitting = false;
      if (createForm) createForm.addEventListener("submit", function (e) {
        if (submitting) { e.preventDefault(); return; }
        submitting = true;
        showOverlay("✨ Creating draft & starting the AI…", "Taking you to the editor…");
      });
    })();
  </script>
</AdminLayout>
