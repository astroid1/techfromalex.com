---
import AdminLayout from "@/layouts/AdminLayout.astro";
import NetworkForm from "@/components/admin/NetworkForm.astro";
import { getDB } from "@/lib/db";
import { nowIso } from "@/lib/ids";
import { slugify } from "@/lib/format";

export const prerender = false;
const db = getDB(Astro.locals);
let error: string | null = null;
let values: Record<string, unknown> = {};

if (Astro.request.method === "POST") {
  const f = await Astro.request.formData();
  const id = slugify(String(f.get("id") ?? "")) || slugify(String(f.get("name") ?? ""));
  const name = String(f.get("name") ?? "").trim();
  const linkParam = String(f.get("link_param") ?? "tag").trim();
  const extra = String(f.get("extra_params_json") ?? "{}").trim() || "{}";
  const paramHelp = String(f.get("param_help") ?? "").trim();
  const isActive = f.get("is_active") ? 1 : 0;
  values = { id, name, link_param: linkParam, extra_params_json: extra, param_help: paramHelp, is_active: isActive };

  if (!id || !name) error = "Network ID and name are required.";
  else {
    try {
      JSON.parse(extra);
    } catch {
      error = "Extra params must be valid JSON.";
    }
  }

  if (!error) {
    const now = nowIso();
    try {
      await db
        .prepare(
          `INSERT INTO networks (id, name, link_param, extra_params_json, param_help, is_active, created_at, updated_at)
           VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,
        )
        .bind(id, name, linkParam, extra, paramHelp || null, isActive, now, now)
        .run();
      return Astro.redirect("/admin/networks");
    } catch (e) {
      const msg = (e as Error).message ?? "";
      error = /UNIQUE|PRIMARY KEY/i.test(msg) ? `A network with id "${id}" already exists.` : msg;
    }
  }
}
---

<AdminLayout title="New network">
  <NetworkForm values={values} error={error} submitLabel="Create network" isNew />
</AdminLayout>
