---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Tech From Alex",
  description = "Tech reviews, guides, and deals to help you buy smarter.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body>
    <slot />
  </body>
</html>
