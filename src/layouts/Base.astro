---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import CommandPalette from "@/components/search/CommandPalette.tsx";

interface Props {
  title?: string;
  description?: string;
  image?: string | null;
  type?: "website" | "article";
  noindex?: boolean;
}
const SITE = "Tech From Alex";
const site = Astro.site ?? new URL(Astro.url.origin);
const {
  title,
  description = "Honest, hands-on tech reviews, buying guides, and deals to help you buy smarter.",
  image,
  type = "website",
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, site).toString();
const fullTitle = title ? `${title} | ${SITE}` : `${SITE} — Tech Reviews, Guides & Deals`;
const ogImage = image ?? null;

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE,
  url: site.toString(),
  potentialAction: {
    "@type": "SearchAction",
    target: `${site.origin}/search?q={query}`,
    "query-input": "required name=query",
  },
};
const orgLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE,
  url: site.toString(),
  logo: new URL("/favicon.svg", site).toString(),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:site_name" content={SITE} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title ?? SITE} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title ?? SITE} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <meta name="theme-color" content="#0a0c12" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE} — RSS`} href="/rss.xml" />

    <script is:inline>
      // Dark is the default; users opt into light via the toggle (stored as theme=light).
      (function () {
        try {
          if (localStorage.getItem("theme") === "light")
            document.documentElement.classList.add("light");
        } catch (e) {}
      })();
      document.addEventListener("astro:after-swap", function () {
        try {
          document.documentElement.classList.toggle(
            "light",
            localStorage.getItem("theme") === "light",
          );
        } catch (e) {}
      });
    </script>

    <ClientRouter />
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} is:inline />
    <slot name="head" />
  </head>
  <body class="flex min-h-[100dvh] flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CommandPalette client:idle />
  </body>
</html>
