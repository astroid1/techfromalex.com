---
import "../styles/global.css";

interface Props {
  title: string;
}
const { title } = Astro.props;
const user = Astro.locals.user;
const path = Astro.url.pathname;

const nav = [
  { label: "Dashboard", href: "/admin" },
  { label: "Content", href: "/admin/content" },
  { label: "Products", href: "/admin/products" },
  { label: "Affiliate profiles", href: "/admin/affiliates" },
  { label: "Programs", href: "/admin/programs" },
  { label: "Networks", href: "/admin/networks" },
  { label: "Media", href: "/admin/media" },
  { label: "Clicks", href: "/admin/clicks" },
];
const active = (href: string) =>
  href === "/admin" ? path === "/admin" : path.startsWith(href);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} · Admin · Tech From Alex</title>
  </head>
  <body class="min-h-[100dvh] bg-paper text-ink">
    <div class="flex min-h-[100dvh]">
      <aside class="hidden w-60 shrink-0 border-r border-line bg-surface p-4 md:block">
        <a href="/admin" class="flex items-center gap-2 px-2 font-display text-lg font-bold">
          <span class="grid h-8 w-8 place-items-center rounded-lg bg-accent text-sm text-accent-contrast">TA</span>
          Admin
        </a>
        <nav class="mt-6 space-y-1">
          {
            nav.map((n) => (
              <a
                href={n.href}
                class={`block rounded-lg px-3 py-2 text-sm font-medium transition ${active(n.href) ? "bg-accent text-accent-contrast" : "text-ink-soft hover:bg-surface-2"}`}
              >
                {n.label}
              </a>
            ))
          }
        </nav>
        <div class="mt-8 border-t border-line pt-4 text-xs text-muted">
          <a href="/" class="block rounded px-3 py-1.5 hover:text-accent-strong">↗ View site</a>
          <a href="/cdn-cgi/access/logout" class="block rounded px-3 py-1.5 hover:text-accent-strong">Sign out</a>
        </div>
      </aside>

      <div class="flex min-w-0 flex-1 flex-col">
        <header class="flex items-center justify-between gap-3 border-b border-line bg-surface px-4 py-3 md:px-6">
          <div class="flex min-w-0 items-center gap-2">
            <details class="relative md:hidden">
              <summary class="grid h-9 w-9 cursor-pointer list-none place-items-center rounded-lg text-ink-soft transition hover:bg-surface-2">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                </svg>
              </summary>
              <nav class="absolute left-0 top-11 z-30 w-56 rounded-xl border border-line bg-surface p-2 shadow-[var(--shadow-lg)]" aria-label="Admin">
                {
                  nav.map((n) => (
                    <a
                      href={n.href}
                      class={`block rounded-lg px-3 py-2 text-sm font-medium transition ${active(n.href) ? "bg-accent text-accent-contrast" : "text-ink-soft hover:bg-surface-2"}`}
                    >
                      {n.label}
                    </a>
                  ))
                }
                <div class="my-1.5 border-t border-line"></div>
                <a href="/" class="block rounded-lg px-3 py-2 text-sm text-ink-soft transition hover:bg-surface-2">↗ View site</a>
                <a href="/cdn-cgi/access/logout" class="block rounded-lg px-3 py-2 text-sm text-ink-soft transition hover:bg-surface-2">Sign out</a>
              </nav>
            </details>
            <h1 class="truncate font-display text-lg font-bold md:text-xl">{title}</h1>
          </div>
          {user && <span class="hidden truncate text-sm text-muted sm:block">{user.email}</span>}
        </header>
        <main class="flex-1 p-6">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
