---
interface Props {
  pros?: string[];
  cons?: string[];
}
const { pros = [], cons = [] } = Astro.props;
---

<div class="not-prose my-8 grid gap-4 sm:grid-cols-2">
  <div class="glass rounded-xl p-5" style="border-top: 3px solid var(--success);">
    <h4 class="mb-3 flex items-center gap-2 font-semibold text-ink">
      <span class="grid h-5 w-5 place-items-center rounded-full text-xs" style="background: color-mix(in srgb, var(--success) 18%, transparent); color: var(--success);">✓</span>
      Pros
    </h4>
    <ul class="space-y-2 text-sm text-ink-soft">
      {pros.map((p) => (
        <li class="flex gap-2">
          <span style="color: var(--success)" class="mt-px shrink-0">✓</span>
          <span>{p}</span>
        </li>
      ))}
    </ul>
  </div>
  <div class="glass rounded-xl p-5" style="border-top: 3px solid var(--danger);">
    <h4 class="mb-3 flex items-center gap-2 font-semibold text-ink">
      <span class="grid h-5 w-5 place-items-center rounded-full text-xs" style="background: color-mix(in srgb, var(--danger) 18%, transparent); color: var(--danger);">✕</span>
      Cons
    </h4>
    <ul class="space-y-2 text-sm text-ink-soft">
      {cons.map((c) => (
        <li class="flex gap-2">
          <span style="color: var(--danger)" class="mt-px shrink-0">✕</span>
          <span>{c}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
