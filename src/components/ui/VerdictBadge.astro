---
interface Props {
  score: number | null | undefined; // 0..10
  label?: string;
  size?: "sm" | "lg";
}
const { score, label = "Verdict", size = "lg" } = Astro.props;
const s = score == null ? null : Math.max(0, Math.min(10, score));
const big = size === "lg";
---

{
  s != null && (
    <div
      class={`inline-flex flex-col items-center justify-center rounded-2xl bg-accent text-accent-contrast shadow-[var(--shadow-md)] ${big ? "px-5 py-3" : "px-3 py-2"}`}
    >
      <span class={`font-display font-bold leading-none ${big ? "text-3xl" : "text-xl"}`}>
        {s.toFixed(1)}
        <span class={`font-sans font-medium opacity-70 ${big ? "text-base" : "text-xs"}`}>/10</span>
      </span>
      <span class={`mt-0.5 font-semibold uppercase tracking-widest opacity-80 ${big ? "text-[10px]" : "text-[9px]"}`}>
        {label}
      </span>
    </div>
  )
}
