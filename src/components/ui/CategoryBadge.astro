---
import { CATEGORY_NAMES, type CategorySlug } from "@/lib/types";

interface Props {
  category: CategorySlug | string | null | undefined;
  href?: boolean;
  /** Dark pill for overlaying on imagery (Engadget-style). */
  overlay?: boolean;
}
const { category, href = true, overlay = false } = Astro.props;
const slug = (category ?? "") as CategorySlug;
const name = CATEGORY_NAMES[slug] ?? category ?? "";
const known = slug in CATEGORY_NAMES;
const dot = known ? `var(--cat-${slug})` : "var(--accent)";
const Tag = href && known ? "a" : "span";
const base =
  "inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[11px] font-bold uppercase tracking-wide transition";
const cls = overlay
  ? `${base} pill-overlay`
  : `${base} border border-line bg-surface-2 text-ink-soft hover:text-ink`;
---

{
  name && (
    <Tag href={href && known ? `/category/${slug}` : undefined} class={cls}>
      <span class="h-1.5 w-1.5 rounded-full" style={`background:${dot}`} />
      {name}
    </Tag>
  )
}
