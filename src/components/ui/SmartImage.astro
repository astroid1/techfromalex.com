---
import { cdnImage } from "@/lib/image";

interface Props {
  src?: string | null;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  eager?: boolean;
}
const { src, alt, width = 1200, height, class: cls = "", eager = false } = Astro.props;
const env = (Astro.locals as any)?.runtime?.env ?? {};
const transform = env.IMAGE_TRANSFORMS === "on";
const url = cdnImage(src, { width, transform });
// Retina/HiDPI: also offer a 2x variant so large (featured/hero) images stay crisp
// on high-density screens instead of upscaling a 1x source. Only emitted when the
// transform actually applies — external pass-through returns the same URL for any
// width, so url2x === url and no srcset is added.
const url2x = cdnImage(src, { width: Math.min(width * 2, 2560), transform });
const srcset = url && url2x && url2x !== url ? `${url} 1x, ${url2x} 2x` : undefined;
---

{
  url ? (
    <img
      src={url}
      srcset={srcset}
      alt={alt}
      width={width}
      height={height}
      loading={eager ? "eager" : "lazy"}
      decoding="async"
      class={cls}
    />
  ) : (
    <div
      class={`grid place-items-center bg-gradient-to-br from-surface-2 via-surface to-line ${cls}`}
      aria-hidden="true"
    >
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" class="text-muted opacity-50">
        <path
          d="M3 16l5-5 4 4 3-3 6 6M3 5h18v14H3V5z"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <circle cx="8.5" cy="9" r="1.5" fill="currentColor" />
      </svg>
    </div>
  )
}
