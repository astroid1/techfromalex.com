---
import SmartImage from "@/components/ui/SmartImage.astro";
import RatingStars from "@/components/ui/RatingStars.astro";
import BuyButton from "@/components/affiliate/BuyButton.astro";
import { formatPrice, formatMonthYear } from "@/lib/format";
import { retailerLabel } from "@/lib/image";
import { goUrl } from "@/lib/clicks";
import { linkHost } from "@/lib/content";
import type { Product } from "@/lib/types";

interface Props {
  product?: Product | null;
  award?: string | null;
  bestFor?: string | null;
  /** Anchor id so a roundup persona chip can jump to this card. */
  anchorId?: string | null;
}
const { product, award, bestFor, anchorId } = Astro.props;
const price = product ? formatPrice(product.priceCents, product.currency) : null;
const checked = formatMonthYear(product?.priceObservedAt);
const priceNote = checked ? `approx. · checked ${checked}` : "approx.";
const others = product?.otherBuyLinks ?? [];
---

{
  product && (
    <aside id={anchorId ?? undefined} class="not-prose glass glow-hover my-8 scroll-mt-24 overflow-hidden rounded-2xl shadow-[var(--shadow-md)]">
      {award && (
        <div class="bg-accent px-4 py-1.5 text-center text-xs font-bold uppercase tracking-widest text-accent-contrast">
          {award}
        </div>
      )}
      <div class="grid gap-0 sm:grid-cols-[210px_1fr]">
        <div class="aspect-square border-b border-line bg-white sm:border-b-0 sm:border-r">
          <SmartImage src={product.imageUrl} alt={product.name} width={420} class="h-full w-full object-contain p-3" />
        </div>
        <div class="flex flex-col gap-3 p-5">
          <div>
            {product.brand && (
              <p class="text-xs font-semibold uppercase tracking-widest text-muted">{product.brand}</p>
            )}
            <h3 class="font-display text-xl font-semibold leading-tight text-ink">{product.name}</h3>
            {typeof bestFor === "string" && bestFor && (
              <p class="mt-1 text-sm font-medium text-accent-strong">Best for {bestFor.toLowerCase()}</p>
            )}
          </div>
          <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
            {product.rating != null && <RatingStars rating={product.rating} showValue />}
            {price && (
              <span class="inline-flex items-baseline gap-1.5">
                <span class="text-lg font-bold text-ink">{price}</span>
                <span class="text-xs font-normal text-muted">{priceNote}</span>
              </span>
            )}
          </div>
          {product.description && (
            <p class="line-clamp-3 text-sm leading-relaxed text-ink-soft">{product.description}</p>
          )}
          <div class="mt-auto space-y-2 pt-1">
            <BuyButton product={product} placement="product-card" />
            {others.length > 0 && (
              <p class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-muted">
                <span>Also at</span>
                {others.map((l) => (
                  <a
                    href={goUrl({ type: "product", id: product.id, network: l.network, host: linkHost(l.url), placement: "also-at" })}
                    target="_blank"
                    rel="nofollow sponsored noopener"
                    class="font-medium text-ink-soft underline-offset-2 hover:underline"
                  >
                    {retailerLabel(l.network, l.url)}
                  </a>
                ))}
              </p>
            )}
          </div>
        </div>
      </div>
    </aside>
  )
}
