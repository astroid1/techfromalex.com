---
import { formatPrice } from "@/lib/format";
import type { Product } from "@/lib/types";

interface Props {
  product?: Product | null;
  priceCents?: number | null;
  currency?: string;
}
const { product, priceCents, currency } = Astro.props;
const cents = product ? product.priceCents : priceCents;
const cur = product ? product.currency : (currency ?? "USD");
const price = formatPrice(cents, cur);
---

<span class="inline-flex items-baseline gap-1 align-middle">
  {
    price ? (
      <span class="inline-flex items-baseline rounded-lg border border-line bg-surface-2 px-2.5 py-1 font-semibold text-ink">
        {price}
      </span>
    ) : (
      <span class="inline-flex items-baseline rounded-lg border border-line bg-surface-2 px-2.5 py-1 text-sm font-medium text-muted">
        View price
      </span>
    )
  }
</span>
