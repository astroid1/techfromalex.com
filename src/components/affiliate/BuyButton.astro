---
import { retailerName } from "@/lib/image";
import type { Product } from "@/lib/types";

interface Props {
  product?: Product | null;
  label?: string;
  block?: boolean;
}
const { product, label, block = false } = Astro.props;
const brand = retailerName(product?.buyNetwork);
// Single source of truth for buy-CTA copy. Retailer-aware "View on Amazon";
// falls back to "View offer" when the network is generic (no brand name).
const text = label ?? (brand === "retailer" ? "View offer" : `View on ${brand}`);
---

{
  product?.buyUrl ? (
    <a
      href={product.buyUrl}
      target="_blank"
      rel="nofollow sponsored noopener"
      class={`btn-accent not-prose group inline-flex items-center justify-center gap-2 rounded-xl px-5 py-3 font-semibold ${block ? "w-full" : ""}`}
    >
      {text}
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="transition group-hover:translate-x-0.5">
        <path d="M5 12h14m-6-6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
  ) : null
}
