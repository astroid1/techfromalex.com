---
import SmartImage from "@/components/ui/SmartImage.astro";
import CategoryBadge from "@/components/ui/CategoryBadge.astro";
import { formatDate } from "@/lib/format";
import type { ContentSummary } from "@/lib/types";

interface Props {
  item: ContentSummary;
  featured?: boolean;
}
const { item, featured = false } = Astro.props;
const href = `/${item.slug}`;
---

<article class="group">
  <a href={href} class="block">
    <div class={`relative overflow-hidden rounded-2xl bg-surface-2 ${featured ? "aspect-[16/9]" : "aspect-[16/10]"}`}>
      <SmartImage
        src={item.heroImageUrl}
        alt={item.heroAlt ?? item.title}
        width={featured ? 1280 : 640}
        eager={featured}
        class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
      />
      <div class="absolute left-3 top-3">
        <CategoryBadge category={item.category} href={false} overlay />
      </div>
      {
        item.verdictScore != null && (
          <span class="pill-overlay absolute right-3 top-3 rounded-full px-2.5 py-1 font-display text-sm font-extrabold">
            {item.verdictScore.toFixed(1)}
          </span>
        )
      }
    </div>
  </a>
  <div class={featured ? "mt-4" : "mt-3"}>
    <h3
      class={`font-display font-extrabold tracking-tight text-ink ${featured ? "text-3xl leading-[1.05] sm:text-4xl lg:text-[2.6rem]" : "text-xl leading-snug"}`}
    >
      <a href={href} class="transition hover:text-accent-strong">{item.title}</a>
    </h3>
    {
      item.dek && (
        <p class={`text-ink-soft ${featured ? "mt-3 max-w-2xl text-lg leading-relaxed" : "mt-2 line-clamp-2 text-sm leading-relaxed"}`}>
          {item.dek}
        </p>
      )
    }
    {
      item.publishedAt && (
        <p class="mt-2 text-xs font-medium text-muted">
          <time datetime={item.publishedAt}>{formatDate(item.publishedAt)}</time>
        </p>
      )
    }
  </div>
</article>
