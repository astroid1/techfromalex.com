---
import type { ContentFull, Product } from "@/lib/types";

interface Props {
  content: ContentFull;
  products: Map<string, Product>;
}
const { content, products } = Astro.props;
const s = content.structured as {
  entrants?: string[];
  overallWinnerId?: string;
  verdict?: string;
};
const entrants = (s.entrants ?? []).map((id) => products.get(id)).filter(Boolean) as Product[];
const winner = s.overallWinnerId ? products.get(s.overallWinnerId) : null;
---

{
  entrants.length > 0 && (
    <div class="not-prose mb-10 rounded-2xl border border-line bg-surface p-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-muted">Head to head</p>
      <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-2 font-display text-2xl font-extrabold tracking-tight text-ink sm:text-3xl">
        {entrants.map((p, i) => (
          <>
            {i > 0 && <span class="text-base font-semibold text-muted">vs</span>}
            <span>{p.name}</span>
          </>
        ))}
      </div>
      {winner && (
        <p class="mt-5 border-t border-line pt-5">
          <span class="text-xs font-semibold uppercase tracking-widest text-accent-strong">Winner</span>
          <span class="ml-2 font-semibold text-ink">{winner.name}</span>
        </p>
      )}
      {s.verdict && <p class="mt-2 text-ink-soft leading-relaxed">{s.verdict}</p>}
    </div>
  )
}
