---
import VerdictBadge from "@/components/ui/VerdictBadge.astro";
import type { ContentFull, Product } from "@/lib/types";

interface Props {
  content: ContentFull;
  products: Map<string, Product>;
}
const { content } = Astro.props;
const s = content.structured as {
  verdictSummary?: string;
  scorecard?: { label?: unknown; score?: unknown }[];
  whoItsFor?: string[];
  whoItsNot?: string[];
};
const whoFor = s.whoItsFor ?? [];
const whoNot = s.whoItsNot ?? [];
const scorecard = (Array.isArray(s.scorecard) ? s.scorecard : []).filter(
  (c): c is { label: string; score: number } =>
    !!c && typeof c.label === "string" && typeof c.score === "number",
);
---

<div class="not-prose glass mb-10 rounded-2xl p-6">
  <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
    <div class="max-w-xl">
      <p class="text-xs font-semibold uppercase tracking-widest text-muted">Our verdict</p>
      {s.verdictSummary && (
        <p class="mt-1.5 font-display text-lg leading-snug text-ink">{s.verdictSummary}</p>
      )}
    </div>
    {content.verdictScore != null && <VerdictBadge score={content.verdictScore} />}
  </div>
  {
    scorecard.length > 0 && (
      <div class="mt-5 grid gap-x-6 gap-y-3 border-t border-line pt-5 sm:grid-cols-2">
        {scorecard.map((c) => (
          <div class="flex items-center gap-3">
            <span class="w-28 shrink-0 truncate text-sm text-ink-soft" title={c.label}>{c.label}</span>
            <div class="h-2 flex-1 overflow-hidden rounded-full bg-surface-2">
              <div class="h-full rounded-full bg-accent" style={`width:${Math.max(0, Math.min(10, c.score)) * 10}%`} />
            </div>
            <span class="w-8 shrink-0 text-right text-sm font-bold tabular-nums text-ink">{c.score.toFixed(1)}</span>
          </div>
        ))}
      </div>
    )
  }
  {
    (whoFor.length > 0 || whoNot.length > 0) && (
      <div class="mt-5 grid gap-5 border-t border-line pt-5 sm:grid-cols-2">
        {whoFor.length > 0 && (
          <div>
            <p class="mb-2 text-sm font-semibold text-ink">Buy it if…</p>
            <ul class="space-y-1.5 text-sm text-ink-soft">
              {whoFor.map((w) => (
                <li class="flex gap-2">
                  <span style="color:var(--success)" class="shrink-0">✓</span>
                  <span>{w}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
        {whoNot.length > 0 && (
          <div>
            <p class="mb-2 text-sm font-semibold text-ink">Skip it if…</p>
            <ul class="space-y-1.5 text-sm text-ink-soft">
              {whoNot.map((w) => (
                <li class="flex gap-2">
                  <span style="color:var(--danger)" class="shrink-0">✕</span>
                  <span>{w}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    )
  }
</div>
