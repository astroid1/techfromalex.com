---
interface Props {
  items?: { q: string; a: string }[];
}
const raw = Astro.props.items ?? [];
const items = raw.filter((f) => f && f.q && f.a);
---

{
  items.length > 0 && (
    <section class="not-prose mt-12 border-t border-line pt-8">
      <h2 class="font-display text-2xl font-extrabold tracking-tight text-ink">Frequently asked questions</h2>
      <div class="mt-5 divide-y divide-line">
        {items.map((f) => (
          <details class="group py-3">
            <summary class="flex cursor-pointer items-center justify-between gap-3 font-semibold text-ink marker:content-none [&::-webkit-details-marker]:hidden">
              <span>{f.q}</span>
              <span class="shrink-0 text-xl leading-none text-muted transition group-open:rotate-45">+</span>
            </summary>
            <p class="mt-2 leading-relaxed text-ink-soft">{f.a}</p>
          </details>
        ))}
      </div>
    </section>
  )
}
