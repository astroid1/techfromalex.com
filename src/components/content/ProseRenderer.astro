---
import type { Segment } from "@/lib/render-body";
import type { Product, ProgramCta } from "@/lib/types";
import ProductCard from "@/components/affiliate/ProductCard.astro";
import BuyButton from "@/components/affiliate/BuyButton.astro";
import ComparisonTable from "@/components/affiliate/ComparisonTable.astro";
import Callout from "@/components/mdx/Callout.astro";
import ProsCons from "@/components/mdx/ProsCons.astro";
import ProgramCtaBlock from "@/components/content/ProgramCta.astro";

interface Props {
  segments: Segment[];
  products: Map<string, Product>;
  programs?: Map<string, ProgramCta>;
  /** productId -> roundup award/best-for, surfaced on in-body product cards. */
  awards?: Map<string, { award?: string | null; bestFor?: string | null }>;
  admin?: boolean;
}
const { segments, products, programs = new Map(), awards = new Map(), admin = false } = Astro.props;
---

<div class="article-body">
  {
    segments.map((seg) => {
      if (seg.kind === "html") {
        return <div class="prose max-w-none" set:html={seg.html} />;
      }
      const p: any = seg.props;
      switch (seg.name) {
        case "product-card": {
          const a = awards.get(p.id);
          return (
            <ProductCard product={products.get(p.id)} award={a?.award ?? null} bestFor={a?.bestFor ?? null} />
          );
        }
        case "buy-button":
          return (
            <div class="my-6">
              <BuyButton product={products.get(p.id)} />
            </div>
          );
        case "comparison":
          return (
            <ComparisonTable products={(p.ids as string[]).map((id) => products.get(id))} />
          );
        case "callout":
          return <Callout type={p.type} title={p.title} bodyHtml={p.bodyHtml} />;
        case "pros-cons":
          return <ProsCons pros={p.pros} cons={p.cons} />;
        case "promo":
          return <ProgramCtaBlock program={programs.get(p.id)} admin={admin} />;
        default:
          return null;
      }
    })
  }
</div>
