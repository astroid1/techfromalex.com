---
import Container from "./Container.astro";
import ThemeToggle from "./ThemeToggle.tsx";

const nav = [
  { label: "Reviews", href: "/category/reviews" },
  { label: "Guides", href: "/category/guides" },
  { label: "Comparisons", href: "/comparisons" },
  { label: "Deals", href: "/deals" },
  { label: "About", href: "/about" },
];
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href + "/");
const mark = "background: var(--accent);";
---

<header class="sticky top-0 z-40 border-b border-line bg-paper">
  <Container width="wide" class="flex h-16 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2.5 font-brand text-xl tracking-wide text-ink sm:text-2xl">
      <span class="grid h-8 w-8 shrink-0 place-items-center rounded-lg font-brand text-sm text-accent-contrast" style={mark}>TA</span>
      <span>Tech From Alex</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {
        nav.map((n) => (
          <a
            href={n.href}
            aria-current={isActive(n.href) ? "page" : undefined}
            class={`rounded-lg px-3 py-2 text-sm font-medium transition ${isActive(n.href) ? "text-accent-strong" : "text-ink-soft hover:bg-surface-2 hover:text-ink"}`}
            style={isActive(n.href) ? "background: color-mix(in srgb, var(--accent) 12%, transparent);" : undefined}
          >
            {n.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-1.5">
      <a
        href="/search"
        data-search-trigger
        aria-label="Search"
        class="group hidden items-center gap-2 rounded-lg border border-line bg-surface-2/60 px-2.5 py-1.5 text-sm text-muted transition hover:border-line-strong hover:text-ink-soft sm:flex"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.9" />
          <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" />
        </svg>
        <span>Search</span>
        <kbd class="rounded border border-line-strong px-1.5 py-px text-[10px] font-medium text-muted">⌘K</kbd>
      </a>
      <a
        href="/search"
        data-search-trigger
        aria-label="Search"
        class="grid h-9 w-9 place-items-center rounded-lg text-ink-soft transition hover:bg-surface-2 hover:text-ink sm:hidden"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8" />
          <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
      </a>
      <ThemeToggle client:load />
      <details class="relative md:hidden">
        <summary class="grid h-9 w-9 cursor-pointer list-none place-items-center rounded-lg text-ink-soft transition hover:bg-surface-2 hover:text-ink">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
            <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          </svg>
        </summary>
        <nav class="glass absolute right-0 mt-2 w-48 rounded-xl p-2 shadow-[var(--shadow-lg)]" aria-label="Mobile">
          {
            nav.map((n) => (
              <a
                href={n.href}
                class={`block rounded-lg px-3 py-2 text-sm font-medium transition hover:bg-surface-2 ${isActive(n.href) ? "text-accent-strong" : "text-ink-soft hover:text-ink"}`}
              >
                {n.label}
              </a>
            ))
          }
        </nav>
      </details>
    </div>
  </Container>
</header>
