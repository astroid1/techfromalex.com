---
import Container from "./Container.astro";
import ThemeToggle from "./ThemeToggle.tsx";

const nav = [
  { label: "Reviews", href: "/category/reviews" },
  { label: "Guides", href: "/category/guides" },
  { label: "Comparisons", href: "/category/comparisons" },
  { label: "Deals", href: "/deals" },
  { label: "About", href: "/about" },
];
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href + "/");
---

<header class="sticky top-0 z-40 border-b border-line bg-paper/85 backdrop-blur-md">
  <Container width="wide" class="flex h-16 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2.5 font-display text-lg font-bold tracking-tight text-ink">
      <span class="grid h-8 w-8 place-items-center rounded-lg bg-accent font-display text-sm text-accent-contrast">TA</span>
      <span class="hidden sm:inline">Tech From Alex</span>
    </a>

    <nav class="hidden items-center gap-7 md:flex" aria-label="Primary">
      {
        nav.map((n) => (
          <a
            href={n.href}
            aria-current={isActive(n.href) ? "page" : undefined}
            class={`text-sm font-medium transition hover:text-accent-strong ${isActive(n.href) ? "text-accent-strong" : "text-ink-soft"}`}
          >
            {n.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-1">
      <a
        href="/search"
        aria-label="Search"
        class="grid h-9 w-9 place-items-center rounded-lg text-ink-soft transition hover:bg-surface-2"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8" />
          <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
      </a>
      <ThemeToggle client:load />
      <details class="relative md:hidden">
        <summary class="grid h-9 w-9 cursor-pointer list-none place-items-center rounded-lg text-ink-soft transition hover:bg-surface-2">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
            <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          </svg>
        </summary>
        <nav class="absolute right-0 mt-2 w-48 rounded-xl border border-line bg-surface p-2 shadow-[var(--shadow-lg)]" aria-label="Mobile">
          {
            nav.map((n) => (
              <a
                href={n.href}
                class={`block rounded-lg px-3 py-2 text-sm font-medium transition hover:bg-surface-2 ${isActive(n.href) ? "text-accent-strong" : "text-ink-soft"}`}
              >
                {n.label}
              </a>
            ))
          }
        </nav>
      </details>
    </div>
  </Container>
</header>
