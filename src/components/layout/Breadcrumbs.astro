---
interface Crumb {
  name: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm text-muted">
  <ol class="flex flex-wrap items-center gap-1.5">
    {
      items.map((c, i) => (
        <li class="flex items-center gap-1.5">
          {c.href ? (
            <a href={c.href} class="text-muted transition hover:text-ink">{c.name}</a>
          ) : (
            <span class="text-ink-soft" aria-current="page">{c.name}</span>
          )}
          {i < items.length - 1 && <span aria-hidden="true" class="text-line-strong">/</span>}
        </li>
      ))
    }
  </ol>
</nav>
